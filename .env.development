# 开发环境配置
VITE_APP_TITLE=博客管理系统(开发)

# API配置（只用于管理后台）
VITE_API_BASE_URL=
# 前台博客API配置（明确区分）
VITE_BLOG_API_BASE_URL=/blog
VITE_USE_MOCK=false

# 调试配置
VITE_APP_DEBUG=true

# 请求路径说明
# 后台管理API: /api/xxx (通过VITE_API_BASE_URL配置)
# 前台博客API: /blog/xxx (通过VITE_BLOG_API_BASE_URL配置)

# 前台博客API通过src/utils/blogRequest.js独立配置，不依赖此处环境变量 